<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="brand-signup-supabase" name="Brand Sign-Up (Supabase)">
    <mxGraphModel dx="418" dy="260" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Background -->
        <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0b1730;strokeColor=#22314f;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1720" height="1520" as="geometry" />
        </mxCell>

        <!-- Title -->
        <mxCell id="title" value="Brand Sign-Up Flow — Apfluence" style="text;html=1;fontColor=#f8fafc;fontStyle=1;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="550" y="52" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- Participant headers -->
        <mxCell id="p1" value="Brand User (Browser)" style="rounded=1;arcSize=10;fillColor=#f97316;strokeColor=#ea580c;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="95" width="180" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="App (BrandSignUpForm)" style="rounded=1;arcSize=10;fillColor=#1d4ed8;strokeColor=#60a5fa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="95" width="190" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="Cloudinary" style="rounded=1;arcSize=10;fillColor=#ea580c;strokeColor=#fed7aa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="710" y="95" width="140" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="Supabase Auth" style="rounded=1;arcSize=10;fillColor=#16a34a;strokeColor=#4ade80;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="95" width="150" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="Brand-Onboard API" style="rounded=1;arcSize=10;fillColor=#7c3aed;strokeColor=#c4b5fd;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1270" y="95" width="170" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p6" value="Middleware" style="rounded=1;arcSize=10;fillColor=#0f766e;strokeColor=#2dd4bf;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1570" y="95" width="130" height="36" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lf1" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#64748b;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="170" y="155" as="sourcePoint"/><mxPoint x="170" y="1520" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf2" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#64748b;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="155" as="sourcePoint"/><mxPoint x="475" y="1520" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf3" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#64748b;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="780" y="155" as="sourcePoint"/><mxPoint x="780" y="1520" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf4" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#64748b;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="155" as="sourcePoint"/><mxPoint x="1065" y="1520" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf5" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#64748b;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1355" y="155" as="sourcePoint"/><mxPoint x="1355" y="1520" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf6" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#64748b;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1635" y="155" as="sourcePoint"/><mxPoint x="1635" y="1520" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 1-2: Open page -->
        <mxCell id="m1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="1. User opens sign-up page (/sign-up/brand)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="170" y="200" as="sourcePoint"/><mxPoint x="475" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="2. App shows form (name, email, website, logo, password, confirm password)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="240" as="sourcePoint"/><mxPoint x="170" y="240" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 3: User fills form -->
        <mxCell id="m3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="3. User fills all fields and clicks Sign Up">
          <mxGeometry relative="1" as="geometry"><mxPoint x="170" y="285" as="sourcePoint"/><mxPoint x="475" y="285" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Client-side validation box -->
        <mxCell id="box_val" value="Client validation checks (before sending to server)" style="rounded=1;fillColor=#1e293b;strokeColor=#475569;opacity=80;fontColor=#cbd5e1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="660" height="130" as="geometry" />
        </mxCell>
        <mxCell id="mv1" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="3A. If name/email/password empty → toast error, stop">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="340" as="sourcePoint"/><mxPoint x="170" y="340" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mv2" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="3B. If passwords don&apos;t match → toast error, stop">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="370" as="sourcePoint"/><mxPoint x="170" y="370" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mv3" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="3C. If password missing uppercase/number/8 chars → toast error, stop">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="400" as="sourcePoint"/><mxPoint x="170" y="400" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mv4" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="3D. If website provided but does not start with http:// → toast error, stop">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="428" as="sourcePoint"/><mxPoint x="170" y="428" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Logo upload box -->
        <mxCell id="box_logo" value="opt: User uploaded a logo file (optional)" style="rounded=1;fillColor=#7c2d12;strokeColor=#fb923c;opacity=20;fontColor=#fed7aa;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="465" width="760" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ml1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#fb923c;fontColor=#fed7aa;labelBackgroundColor=none;fontSize=10;" value="4. App uploads logo file to Cloudinary (POST /v1_1/.../image/upload)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="495" as="sourcePoint"/><mxPoint x="780" y="495" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ml2" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fb923c;fontColor=#fed7aa;labelBackgroundColor=none;fontSize=10;" value="5. Cloudinary returns logo URL (secure_url)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="780" y="530" as="sourcePoint"/><mxPoint x="475" y="530" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 6: Call supabase.auth.signUp -->
        <mxCell id="m6" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="6. App calls supabase.auth.signUp(email, password, full_name)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="590" as="sourcePoint"/><mxPoint x="1065" y="590" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="7. Supabase creates account and validates email uniqueness">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="630" as="sourcePoint"/><mxPoint x="475" y="630" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ALT 1: Sign-up FAILED -->
        <mxCell id="a1" value="alt 1: Sign-up failed" style="rounded=1;fillColor=#78350f;strokeColor=#f59e0b;opacity=18;fontColor=#fef3c7;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="660" width="1000" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m8a" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="8A. Supabase returns error (email already exists / invalid) → App shows toast error">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="700" as="sourcePoint"/><mxPoint x="170" y="700" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ALT 2: Sign-up SUCCESS — two paths based on email confirmation -->
        <mxCell id="a2" value="alt 2: Sign-up success" style="rounded=1;fillColor=#14532d;strokeColor=#22c55e;opacity=18;fontColor=#dcfce7;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="765" width="1590" height="700" as="geometry" />
        </mxCell>

        <!-- Path A: No session (email confirmation required) -->
        <mxCell id="box_noSession" value="alt 2A: Email confirmation required (no session yet)" style="rounded=1;fillColor=#1e3a5f;strokeColor=#3b82f6;opacity=30;fontColor=#bfdbfe;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="800" width="1540" height="350" as="geometry" />
        </mxCell>

        <mxCell id="m9a" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#93c5fd;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="9A. Supabase returns: account created but NO session (email not yet confirmed)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="840" as="sourcePoint"/><mxPoint x="475" y="840" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10a" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#93c5fd;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="10A. App saves pending data to localStorage: { company_name, website, logo_url }">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="880" as="sourcePoint"/><mxPoint x="170" y="880" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m11a" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#93c5fd;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="11A. Supabase emails the user a 6-digit OTP code">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="920" as="sourcePoint"/><mxPoint x="170" y="920" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m12a" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#93c5fd;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="12A. App redirects user to /sign-up/brand/verify?email=...">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="960" as="sourcePoint"/><mxPoint x="170" y="960" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Verify loop -->
        <mxCell id="box_verify" value="loop: User enters OTP code on verify page (can resend if needed)" style="rounded=1;fillColor=#1e293b;strokeColor=#6366f1;opacity=40;fontColor=#c7d2fe;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="985" width="1480" height="145" as="geometry" />
        </mxCell>
        <mxCell id="m13a" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#818cf8;fontColor=#c7d2fe;labelBackgroundColor=none;fontSize=10;" value="13A. User enters OTP code → App calls supabase.auth.verifyOtp(email, token)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="170" y="1020" as="sourcePoint"/><mxPoint x="1065" y="1020" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m13r" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#818cf8;fontColor=#c7d2fe;labelBackgroundColor=none;dashed=1;fontSize=10;" value="If wrong code: Supabase returns error → App shows error message → User retries">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="1055" as="sourcePoint"/><mxPoint x="170" y="1055" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m14a" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#818cf8;fontColor=#c7d2fe;labelBackgroundColor=none;fontSize=10;" value="14A. Code is correct → Supabase returns session (access_token)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="1105" as="sourcePoint"/><mxPoint x="475" y="1105" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- After verify: call onboard API -->
        <mxCell id="m15a" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="15A. App reads pending data from localStorage + calls POST /api/auth/brand-onboard">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="1160" as="sourcePoint"/><mxPoint x="1355" y="1160" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m16a" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="16A. API creates brand profile in DB → returns 200 OK → App deletes localStorage data">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1355" y="1200" as="sourcePoint"/><mxPoint x="475" y="1200" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Path B: Session returned immediately -->
        <mxCell id="box_session" value="alt 2B: Session returned immediately (no email confirmation needed)" style="rounded=1;fillColor=#14532d;strokeColor=#4ade80;opacity=25;fontColor=#dcfce7;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="1235" width="1540" height="90" as="geometry" />
        </mxCell>
        <mxCell id="m9b" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="9B. Supabase returns session immediately → App calls POST /api/auth/brand-onboard with access_token">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="1265" as="sourcePoint"/><mxPoint x="475" y="1265" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10b2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="10B. App sends company_name, website, logo_url to brand-onboard API">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="1295" as="sourcePoint"/><mxPoint x="1355" y="1295" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Final shared steps: navigate + middleware -->
        <mxCell id="m17" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="17. Brand profile created in DB → App navigates to /brand (dashboard)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="475" y="1360" as="sourcePoint"/><mxPoint x="1635" y="1360" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m18" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="18. Middleware reads session cookie → calls supabase.auth.getUser()">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1635" y="1400" as="sourcePoint"/><mxPoint x="1065" y="1400" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m19" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="19. Middleware checks DB: user in &apos;brands&apos; table? → role = &apos;brand&apos;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1635" y="1440" as="sourcePoint"/><mxPoint x="1065" y="1440" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m20" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="20. Role matches → Access granted → Dashboard displayed">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1635" y="1480" as="sourcePoint"/><mxPoint x="170" y="1480" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
