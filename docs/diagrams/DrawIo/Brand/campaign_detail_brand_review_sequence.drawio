<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="campaign-detail-review" name="Campaign Detail — Brand Review">
    <mxGraphModel dx="1300" dy="860" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1820" height="1620" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Campaign Detail Page — Brand Reviews &amp; Manages Influencers" style="text;html=1;fontColor=#f8fafc;fontStyle=1;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="52" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- Participants -->
        <mxCell id="p1" value="Brand User&#xa;(Browser)" style="rounded=1;arcSize=12;fillColor=#f97316;strokeColor=#ea580c;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="95" width="150" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="Campaign Detail Page&#xa;/brand/campaigns/[id]" style="rounded=1;arcSize=12;fillColor=#2563eb;strokeColor=#60a5fa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="95" width="200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="Server Action&#xa;lib/queries/campaigns.ts" style="rounded=1;arcSize=12;fillColor=#7c3aed;strokeColor=#a78bfa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="95" width="200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="Supabase DB&#xa;campaign_influencers" style="rounded=1;arcSize=12;fillColor=#be185d;strokeColor=#f472b6;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="95" width="200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="Supabase DB&#xa;brands table" style="rounded=1;arcSize=12;fillColor=#0369a1;strokeColor=#38bdf8;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1400" y="95" width="200" height="44" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lf1" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="145" y="160" as="sourcePoint"/><mxPoint x="145" y="1620" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf2" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="160" as="sourcePoint"/><mxPoint x="430" y="1620" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf3" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="780" y="160" as="sourcePoint"/><mxPoint x="780" y="1620" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf4" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="1150" y="160" as="sourcePoint"/><mxPoint x="1150" y="1620" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf5" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="1500" y="160" as="sourcePoint"/><mxPoint x="1500" y="1620" as="targetPoint"/></mxGeometry></mxCell>

        <!-- LOAD -->
        <mxCell id="sec1" value="PART A — Page loads campaign data" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="218" width="400" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="1. Brand opens campaign: /brand/campaigns/[id]">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="255" as="sourcePoint"/><mxPoint x="430" y="255" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="2. Page calls getCampaignById(campaignId) → joins campaign_influencers + influencer profiles">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="295" as="sourcePoint"/><mxPoint x="1150" y="295" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="3. Page also reads brands table to get company_name (used in email later)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="335" as="sourcePoint"/><mxPoint x="1500" y="335" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="4. Page shows: campaign header, pipeline bar (Form Sent → Accepted → Shipped → Drafted → Published → Paid), full influencer table">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="375" as="sourcePoint"/><mxPoint x="145" y="375" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Empty state -->
        <mxCell id="box_empty" value="opt: No influencers in campaign yet" style="rounded=1;fillColor=#1e293b;strokeColor=#475569;opacity=80;fontColor=#cbd5e1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="400" width="700" height="45" as="geometry" />
        </mxCell>
        <mxCell id="m4b" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#94a3b8;fontColor=#cbd5e1;labelBackgroundColor=none;fontSize=10;" value="4B. Page shows empty state with &quot;Add creators from my lists&quot; button">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="422" as="sourcePoint"/><mxPoint x="145" y="422" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Pipeline overview -->
        <mxCell id="box_pipeline" value="Pipeline bar counts influencers per stage automatically:&#xa;Form Sent = email_sent status | Accepted = accepted status | Shipped / Drafted / Published / Paid = manual progression stages" style="rounded=1;fillColor=#1e3a5f;strokeColor=#3b82f6;opacity=30;fontColor=#bfdbfe;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="455" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- PART B: Search + select -->
        <mxCell id="sec2" value="PART B — Brand selects influencers to work with" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="525" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m5" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="5. Brand types in search box → table filters influencers by name/username instantly (no server call)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="562" as="sourcePoint"/><mxPoint x="430" y="562" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="6. Brand ticks checkboxes (or &quot;Select All&quot;) → toolbar shows: Email, Create payments, Set offers buttons">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="602" as="sourcePoint"/><mxPoint x="430" y="602" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART C: Set custom offer -->
        <mxCell id="sec3" value="PART C — Set a custom payment offer for selected influencers" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="640" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="mo1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="7. Brand clicks &quot;Set offers&quot; → modal opens with input pre-filled from campaign default flat amount">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="678" as="sourcePoint"/><mxPoint x="430" y="678" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mo2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="8. Brand types a custom dollar amount → clicks &quot;Save offers&quot;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="718" as="sourcePoint"/><mxPoint x="430" y="718" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mo3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="9. Page calls updateCampaignInfluencerOffer() for each selected influencer (in parallel)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="758" as="sourcePoint"/><mxPoint x="1150" y="758" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mo4" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="10. DB saves custom_flat_amount per influencer row → table updates instantly (Your Offer column)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1150" y="798" as="sourcePoint"/><mxPoint x="145" y="798" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART D: Remove influencer -->
        <mxCell id="sec4" value="PART D — Remove an influencer from the campaign" style="text;html=1;fontColor=#f87171;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="840" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="mr1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#f87171;fontColor=#fca5a5;labelBackgroundColor=none;fontSize=10;" value="11. Brand hovers a row → trash icon appears → brand clicks trash">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="878" as="sourcePoint"/><mxPoint x="430" y="878" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mr2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#f87171;fontColor=#fca5a5;labelBackgroundColor=none;fontSize=10;" value="12. Page calls removeInfluencerFromCampaign(campaignId, influencer_id)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="918" as="sourcePoint"/><mxPoint x="780" y="918" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mr3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#f87171;fontColor=#fca5a5;labelBackgroundColor=none;fontSize=10;" value="13. Server deletes row from campaign_influencers table">
          <mxGeometry relative="1" as="geometry"><mxPoint x="780" y="958" as="sourcePoint"/><mxPoint x="1150" y="958" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mr4" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#f87171;fontColor=#fca5a5;labelBackgroundColor=none;fontSize=10;" value="14. Row removed from table immediately → pipeline counts update automatically">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="998" as="sourcePoint"/><mxPoint x="145" y="998" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART E: Influencer responses -->
        <mxCell id="sec5" value="PART E — Brand reads influencer responses (from apply page)" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="1040" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="box_status" value="The Status column in the table reflects the influencer&apos;s response:&#xa;  • pending → &apos;Ready to invite&apos; (not yet emailed)&#xa;  • email_sent → &apos;Email sent&apos; (brand sent bulk email)&#xa;  • accepted → &apos;Accepted&apos; (influencer accepted on /apply page)&#xa;  • declined → &apos;Declined&apos; (influencer refused)&#xa;  • no_response → &apos;No response&apos; (link opened but no action taken)" style="rounded=1;fillColor=#1e3a5f;strokeColor=#3b82f6;opacity=30;fontColor=#bfdbfe;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1072" width="900" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ms1" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="15. Brand sees live status for each influencer — table updates on page refresh after influencer responds">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="1197" as="sourcePoint"/><mxPoint x="145" y="1197" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART F: Jump to discovery -->
        <mxCell id="sec6" value="PART F — Find more matching creators" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="1235" width="400" height="22" as="geometry" />
        </mxCell>
        <mxCell id="md1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="16. Brand clicks &quot;Find matching creators&quot; button in the filter bar">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="1272" as="sourcePoint"/><mxPoint x="430" y="1272" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="md2" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="17. Page reads campaign filters (country, city, niche, follower range) → navigates to /brand/discovery?countries=...&amp;niches=...">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="1312" as="sourcePoint"/><mxPoint x="145" y="1312" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART G: Add creators -->
        <mxCell id="sec7" value="PART G — Add more creators from a list to this campaign" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="1350" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="ma1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="18. Brand clicks &quot;Add creators&quot; → AddCreatorsModal opens and loads brand lists">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="1388" as="sourcePoint"/><mxPoint x="430" y="1388" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="19. Brand picks a list → Page calls addListInfluencersToCampaign(campaignId, listId)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="1428" as="sourcePoint"/><mxPoint x="780" y="1428" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="20. Server inserts influencers from that list into campaign_influencers (duplicates skipped silently)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="780" y="1468" as="sourcePoint"/><mxPoint x="1150" y="1468" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma4" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="21. Modal shows &quot;Added X creators (Y already in campaign)&quot; → Page reloads campaign data → table updates">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="1508" as="sourcePoint"/><mxPoint x="145" y="1508" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
