<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="bulk-email-send" name="Bulk Email Send">
    <mxGraphModel dx="1300" dy="860" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Background -->
        <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1820" height="1820" as="geometry" />
        </mxCell>

        <!-- Title -->
        <mxCell id="title" value="Bulk Email Outreach — Sending Personalized Emails to Influencers" style="text;html=1;fontColor=#f8fafc;fontStyle=1;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="52" width="1000" height="30" as="geometry" />
        </mxCell>

        <!-- Participants -->
        <mxCell id="p1" value="Brand User&#xa;(Browser)" style="rounded=1;arcSize=12;fillColor=#f97316;strokeColor=#ea580c;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="95" width="150" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="Bulk Email Panel&#xa;(UI Component)" style="rounded=1;arcSize=12;fillColor=#2563eb;strokeColor=#60a5fa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="95" width="180" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="Gmail Setup Modal&#xa;(SMTP Config)" style="rounded=1;arcSize=12;fillColor=#1e293b;strokeColor=#475569;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="95" width="180" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="Email API Route&#xa;(server endpoint)" style="rounded=1;arcSize=12;fillColor=#7c3aed;strokeColor=#a78bfa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="940" y="95" width="180" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="SMTP Server&#xa;(Gmail)" style="rounded=1;arcSize=12;fillColor=#0f766e;strokeColor=#2dd4bf;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1240" y="95" width="180" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p6" value="Supabase DB&#xa;(campaign influencers)" style="rounded=1;arcSize=12;fillColor=#be185d;strokeColor=#f472b6;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1540" y="95" width="200" height="44" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lf1" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="160" as="sourcePoint"/><mxPoint x="145" y="1820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf2" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="160" as="sourcePoint"/><mxPoint x="430" y="1820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf3" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="730" y="160" as="sourcePoint"/><mxPoint x="730" y="1820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf4" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="160" as="sourcePoint"/><mxPoint x="1030" y="1820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf5" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1330" y="160" as="sourcePoint"/><mxPoint x="1330" y="1820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lf6" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1640" y="160" as="sourcePoint"/><mxPoint x="1640" y="1820" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART A: Opening the panel -->
        <mxCell id="sec1" value="PART A — Brand opens the email panel from a campaign" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="218" width="700" height="22" as="geometry" />
        </mxCell>

        <mxCell id="m1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="1. Brand is inside an active campaign → selects the influencers to email">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="255" as="sourcePoint"/><mxPoint x="430" y="255" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="2. Brand clicks &quot;Email Selected&quot; button → Bulk Email Panel slides open">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="295" as="sourcePoint"/><mxPoint x="430" y="295" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="3. Panel pre-fills subject &amp; message body from campaign saved templates">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="335" as="sourcePoint"/><mxPoint x="430" y="365" as="targetPoint"/><Array as="points"><mxPoint x="460" y="335"/><mxPoint x="460" y="365"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="m4" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="4. Panel checks if Gmail is already connected (reads saved settings from DB)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="400" as="sourcePoint"/><mxPoint x="1640" y="400" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="5. Panel shows the list of recipients — warns if any influencer is missing an email address">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="440" as="sourcePoint"/><mxPoint x="145" y="440" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART B: Personalizing the message -->
        <mxCell id="sec2" value="PART B — Brand personalizes the message" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="485" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m6" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="6. Brand clicks &quot;Merge Fields&quot; → inserts placeholders like {{first_name}} or {{campaign_name}} into the message">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="523" as="sourcePoint"/><mxPoint x="430" y="523" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="7. Brand switches to &quot;Preview&quot; mode → sees the real email as it will look for each influencer">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="563" as="sourcePoint"/><mxPoint x="430" y="563" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- opt: Save as campaign default -->
        <mxCell id="box_save" value="opt: Brand saves the template for this campaign" style="rounded=1;fillColor=#1e293b;strokeColor=#475569;opacity=80;fontColor=#cbd5e1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="595" width="1200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ms1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#94a3b8;fontColor=#cbd5e1;labelBackgroundColor=none;fontSize=10;" value="8. Brand clicks &quot;Save as default&quot; → subject &amp; body are saved to the campaign in the database">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="625" as="sourcePoint"/><mxPoint x="1640" y="625" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ms2" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#94a3b8;fontColor=#cbd5e1;labelBackgroundColor=none;fontSize=10;" value="9. Next time Brand opens the panel, the saved template loads automatically">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1640" y="655" as="sourcePoint"/><mxPoint x="145" y="655" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART C: Sending -->
        <mxCell id="sec3" value="PART C — Brand sends the emails" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="710" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m8" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="10. Brand clicks &quot;Send to X influencers&quot; button">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="748" as="sourcePoint"/><mxPoint x="430" y="748" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- alt: Gmail not configured -->
        <mxCell id="box_smtp" value="alt: Gmail is not connected yet" style="rounded=1;fillColor=#78350f;strokeColor=#f59e0b;opacity=18;fontColor=#fef3c7;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="783" width="900" height="130" as="geometry" />
        </mxCell>
        <mxCell id="ma1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="10A. A &quot;Connect Gmail&quot; modal pops up asking for the App Password">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="813" as="sourcePoint"/><mxPoint x="730" y="813" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="10B. Brand enters their Gmail App Password → it is saved securely in the database">
          <mxGeometry relative="1" as="geometry"><mxPoint x="730" y="853" as="sourcePoint"/><mxPoint x="1640" y="853" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma3" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="10C. Modal closes → sending continues automatically">
          <mxGeometry relative="1" as="geometry"><mxPoint x="730" y="893" as="sourcePoint"/><mxPoint x="430" y="893" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Build and send payload -->
        <mxCell id="m9" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="11. Panel builds a personalized email for each influencer (merge fields filled with real names etc.) → sends to server">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="950" as="sourcePoint"/><mxPoint x="1030" y="950" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART D: Server processes batch -->
        <mxCell id="sec4" value="PART D — Server sends emails one by one" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="980" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="msrv1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="12. Server connects to Gmail using the brand's saved credentials">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1010" as="sourcePoint"/><mxPoint x="1330" y="1010" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Loop: for each influencer -->
        <mxCell id="box_loop" value="loop: repeat for every influencer in the batch" style="rounded=1;fillColor=#1e3a5f;strokeColor=#3b82f6;opacity=20;fontColor=#bfdbfe;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="1045" width="800" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ml1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="13. Server sends the personalized email to one influencer via Gmail">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1075" as="sourcePoint"/><mxPoint x="1330" y="1075" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ml2" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="14. Gmail confirms: sent OK or failed">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1330" y="1115" as="sourcePoint"/><mxPoint x="1030" y="1115" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ml3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="15. If sent OK → status updated to &quot;Email Sent&quot; in the campaign; event logged in activity log">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1155" as="sourcePoint"/><mxPoint x="1640" y="1155" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ml4" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="16. A short delay is added between emails to avoid Gmail spam blocks">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1220" as="sourcePoint"/><mxPoint x="1030" y="1235" as="targetPoint"/><Array as="points"><mxPoint x="1060" y="1220"/><mxPoint x="1060" y="1235"/></Array></mxGeometry>
        </mxCell>

        <!-- Final response -->
        <mxCell id="m10" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="17. Server responds with total results: how many were sent and how many failed">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1285" as="sourcePoint"/><mxPoint x="430" y="1285" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PART E: UI feedback -->
        <mxCell id="sec5" value="PART E — Brand sees the result" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="1315" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m11" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="18. Panel shows a success banner: &quot;X emails sent!&quot;">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="1355" as="sourcePoint"/><mxPoint x="145" y="1355" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m12" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="19. If all sent OK → panel closes automatically after a few seconds and campaign data refreshes">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="1395" as="sourcePoint"/><mxPoint x="145" y="1395" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Error: Auth failed -->
        <mxCell id="sec_err" value="ERROR HANDLING" style="text;html=1;fontColor=#f87171;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="1445" width="400" height="22" as="geometry" />
        </mxCell>
        <mxCell id="box_err1" value="alt: Gmail login failed (wrong App Password)" style="rounded=1;fillColor=#78350f;strokeColor=#f59e0b;opacity=18;fontColor=#fef3c7;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1475" width="1100" height="65" as="geometry" />
        </mxCell>
        <mxCell id="me1" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#fde68a;fontColor=#fef3c7;labelBackgroundColor=none;fontSize=10;" value="Server tells the panel: login failed → &quot;Connect Gmail&quot; modal opens again so brand can fix the password">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1510" as="sourcePoint"/><mxPoint x="430" y="1510" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="box_err2" value="alt: Some emails failed (partial failure)" style="rounded=1;fillColor=#1e293b;strokeColor=#475569;opacity=80;fontColor=#cbd5e1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1560" width="1100" height="65" as="geometry" />
        </mxCell>
        <mxCell id="me2" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#94a3b8;fontColor=#cbd5e1;labelBackgroundColor=none;fontSize=10;" value="Panel stays open → shows &quot;X sent, Y failed&quot; → Brand can select failed ones and try again">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1595" as="sourcePoint"/><mxPoint x="145" y="1595" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Merge fields note -->
        <mxCell id="note_mf" value="Merge Fields: {{first_name}}, {{last_name}}, {{influencer_name}}, {{campaign_name}}, {{brand_name}}, {{application_link}}" style="rounded=1;fillColor=#1e293b;strokeColor=#475569;opacity=80;fontColor=#94a3b8;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="1660" width="900" height="44" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
