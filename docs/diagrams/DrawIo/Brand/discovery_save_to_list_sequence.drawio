<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="discovery-save" name="Discovery + Save to List">
    <mxGraphModel dx="1300" dy="860" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Background -->
        <mxCell id="bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1820" height="1720" as="geometry" />
        </mxCell>

        <!-- Title -->
        <mxCell id="title" value="Influencer Discovery &amp; Save to List — Apfluence" style="text;html=1;fontColor=#f8fafc;fontStyle=1;fontSize=15;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="52" width="800" height="30" as="geometry" />
        </mxCell>

        <!-- Participants -->
        <mxCell id="p1" value="Brand User&#xa;(Browser)" style="rounded=1;arcSize=12;fillColor=#f97316;strokeColor=#ea580c;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="95" width="150" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="Discovery Page&#xa;(/brand/discovery)" style="rounded=1;arcSize=12;fillColor=#2563eb;strokeColor=#60a5fa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="95" width="180" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="Influencer Side Panel&#xa;(Drawer)" style="rounded=1;arcSize=12;fillColor=#1e293b;strokeColor=#475569;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="95" width="190" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="Save to List Button&#xa;(UI Component)" style="rounded=1;arcSize=12;fillColor=#7c3aed;strokeColor=#a78bfa;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="940" y="95" width="180" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="Server Actions&#xa;(lists.client.ts)" style="rounded=1;arcSize=12;fillColor=#0369a1;strokeColor=#38bdf8;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1240" y="95" width="200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="p6" value="Supabase DB&#xa;(lists &amp; list_influencers)" style="rounded=1;arcSize=12;fillColor=#be185d;strokeColor=#f472b6;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1560" y="95" width="200" height="44" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="lf1" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="145" y="160" as="sourcePoint"/><mxPoint x="145" y="1700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf2" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="430" y="160" as="sourcePoint"/><mxPoint x="430" y="1700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf3" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="735" y="160" as="sourcePoint"/><mxPoint x="735" y="1700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf4" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="160" as="sourcePoint"/><mxPoint x="1030" y="1700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf5" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="1340" y="160" as="sourcePoint"/><mxPoint x="1340" y="1700" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="lf6" edge="1" parent="1" style="endArrow=none;dashed=1;strokeColor=#94a3b8;"><mxGeometry relative="1" as="geometry"><mxPoint x="1660" y="160" as="sourcePoint"/><mxPoint x="1660" y="1700" as="targetPoint"/></mxGeometry></mxCell>

        <!-- STEP 1: Discovery & Search -->
        <mxCell id="sec1" value="STEP 1 — Brand searches for influencers" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="218" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="1. Brand opens the Discovery page">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="255" as="sourcePoint"/><mxPoint x="430" y="255" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="2. Page loads all influencers from the database">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="295" as="sourcePoint"/><mxPoint x="1660" y="295" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="3. Brand applies filters: niche, follower count, platform, location, keywords">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="335" as="sourcePoint"/><mxPoint x="430" y="335" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="4. List updates instantly (no page reload — filtering happens in the browser)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="375" as="sourcePoint"/><mxPoint x="145" y="375" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- STEP 2: Viewing Details -->
        <mxCell id="sec2" value="STEP 2 — Brand opens influencer details" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="420" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m5" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="5. Brand clicks an influencer card from the results">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="458" as="sourcePoint"/><mxPoint x="430" y="458" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="6. A side panel slides out from the right side of the screen">
          <mxGeometry relative="1" as="geometry"><mxPoint x="430" y="498" as="sourcePoint"/><mxPoint x="735" y="498" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="7. Side panel shows: platforms, posts, follower count, engagement rate, bio, contact info">
          <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="538" as="sourcePoint"/><mxPoint x="145" y="538" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- STEP 3: Save to List -->
        <mxCell id="sec3" value="STEP 3 — Brand saves the influencer to a list" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="585" width="500" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m8" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="8. Brand clicks the &quot;Save to List&quot; button inside the side panel">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="623" as="sourcePoint"/><mxPoint x="1030" y="623" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="9. Button opens a dropdown → fetches all brand lists + checks which ones already include this influencer">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="663" as="sourcePoint"/><mxPoint x="1340" y="663" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="10. Database returns brand's saved lists with member counts">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1340" y="703" as="sourcePoint"/><mxPoint x="1660" y="703" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m11" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="11. Dropdown appears — lists show member counts; lists where influencer is already saved show a blue checkmark">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="743" as="sourcePoint"/><mxPoint x="145" y="743" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- alt: No lists yet -->
        <mxCell id="box_nolist" value="alt: Brand has no lists yet" style="rounded=1;fillColor=#1e293b;strokeColor=#475569;opacity=80;fontColor=#cbd5e1;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="775" width="900" height="80" as="geometry" />
        </mxCell>
        <mxCell id="mn1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#94a3b8;fontColor=#cbd5e1;labelBackgroundColor=none;fontSize=10;" value="11A. Dropdown shows &quot;No lists yet&quot; message + &quot;Create a new list&quot; option">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="800" as="sourcePoint"/><mxPoint x="145" y="800" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mn2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#94a3b8;fontColor=#cbd5e1;labelBackgroundColor=none;fontSize=10;" value="11B. Brand types a name → new list is created in DB → influencer is added to it automatically">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="835" as="sourcePoint"/><mxPoint x="1660" y="835" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- STEP 4: Toggle a list -->
        <mxCell id="sec4" value="STEP 4 — Brand toggles the influencer in/out of a list" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="890" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="box_toggle" value="alt: Brand clicks a list name in the dropdown" style="rounded=1;fillColor=#1e3a5f;strokeColor=#3b82f6;opacity=20;fontColor=#bfdbfe;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="920" width="1650" height="290" as="geometry" />
        </mxCell>
        <mxCell id="ma1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="12. Brand clicks a list name">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="960" as="sourcePoint"/><mxPoint x="1030" y="960" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="13. Checkbox toggles immediately on screen (no waiting — optimistic update)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1000" as="sourcePoint"/><mxPoint x="1030" y="1030" as="targetPoint"/><Array as="points"><mxPoint x="1060" y="1000"/><mxPoint x="1060" y="1030"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="ma3" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="14. App calls Add or Remove influencer from list (depends on current state)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1060" as="sourcePoint"/><mxPoint x="1340" y="1060" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma4" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="15. Database saves or removes the influencer from that list">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1340" y="1100" as="sourcePoint"/><mxPoint x="1660" y="1100" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="ma5" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#bfdbfe;fontColor=#bfdbfe;labelBackgroundColor=none;fontSize=10;" value="16. Success → UI keeps the new state. If error → UI reverts the checkbox back">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1340" y="1175" as="sourcePoint"/><mxPoint x="1030" y="1175" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- OPTIONAL: Quick-save from card -->
        <mxCell id="sec5" value="OPTIONAL — Quick-save directly from the result card" style="text;html=1;fontColor=#22d3ee;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="70" y="1255" width="600" height="22" as="geometry" />
        </mxCell>
        <mxCell id="mb1" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="17. Brand clicks the bookmark icon on any result card (without opening the side panel)">
          <mxGeometry relative="1" as="geometry"><mxPoint x="145" y="1293" as="sourcePoint"/><mxPoint x="1030" y="1293" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mb2" edge="1" parent="1" style="endArrow=block;endFill=1;strokeColor=#e2e8f0;fontColor=#f8fafc;labelBackgroundColor=none;fontSize=10;" value="18. If influencer is not saved anywhere → automatically adds to the most recently created list">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1333" as="sourcePoint"/><mxPoint x="1660" y="1333" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="mb3" edge="1" parent="1" style="endArrow=open;dashed=1;strokeColor=#86efac;fontColor=#dcfce7;labelBackgroundColor=none;fontSize=10;" value="19. Icon turns blue instantly on the card to confirm it was saved">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1373" as="sourcePoint"/><mxPoint x="145" y="1373" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="Note: The side panel loads follower count, engagement rate, and estimated price from a separate metrics table in the database." style="rounded=1;fillColor=#1e293b;strokeColor=#475569;opacity=80;fontColor=#94a3b8;align=left;verticalAlign=top;spacingTop=5;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="1450" width="800" height="44" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
